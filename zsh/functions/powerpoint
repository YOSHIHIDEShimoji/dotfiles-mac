# PowerPoint で開く
powerpoint() {
	local filepath="$1"
	local template="$DOTFILES/templates/empty.pptx"

	if [ -z "$filepath" ]; then
		echo "Usage: powerpoint [path]"
		return 1
	fi

	[[ "$filepath" != *.pptx ]] && filepath="${filepath}.pptx"
	[ ! -f "$filepath" ] && cp "$template" "$filepath"

	if [[ "$(uname)" == "Darwin" ]]; then
		open -a "Microsoft PowerPoint" "$filepath"
	elif [[ -n "$WSL_DISTRO_NAME" ]] || grep -qi microsoft /proc/version 2>/dev/null; then
		local winpath
		winpath=$(wslpath -w "$filepath" 2>/dev/null || echo "$filepath")
		powershell.exe -c "Start-Process '$winpath'"
	fi
}
