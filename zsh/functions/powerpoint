# PowerPoint で開く（open -a）
powerpoint() {
	local filepath="$1"
	local template="${DOTFILES:-$HOME/dotfiles}/templates/template.pptx"

	if [ -z "$filepath" ]; then
		echo "Usage: powerpoint [path]"
		return 1
	fi

	[[ "$filepath" != *.pptx ]] && filepath="${filepath}.pptx"
	[ ! -f "$filepath" ] && cp "$template" "$filepath"

	open -a "Microsoft PowerPoint" "$filepath"
}
