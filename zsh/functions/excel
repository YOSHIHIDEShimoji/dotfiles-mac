# Excel で開く（open -a）
excel() {
	local filepath="$1"
	local template="${DOTFILES:-$HOME/dotfiles}/templates/template.xlsx"

	if [ -z "$filepath" ]; then
		echo "Usage: excel [path]"
		return 1
	fi

	[[ "$filepath" != *.xlsx ]] && filepath="${filepath}.xlsx"
	[ ! -f "$filepath" ] && cp "$template" "$filepath"

	open -a "Microsoft Excel" "$filepath"
}
