cm() {
  local DO_PUSH=false
  local SKIP_CONFIRM=false

  while [[ $# -gt 0 ]]; do
    case "$1" in
      -p) DO_PUSH=true ;;
      -y) SKIP_CONFIRM=true ;;
      *) echo "Usage: cm [-p] [-y]" >&2; return 1 ;;
    esac
    shift
  done

  if [[ -z "$(git diff --cached --name-only)" ]]; then
    echo "Error: No staged changes. Use 'git add' first." >&2
    return 1
  fi

  local diff
  diff=$(git diff --cached)

  if [[ -z "$diff" ]]; then
    echo "Error: Staged changes are empty." >&2
    return 1
  fi

  local BASE_PROMPT=$'このgit diffの内容を見て、適切なコミットメッセージを日本語で1行で書いてください。メッセージだけを出力して、説明や補足は一切不要です。'

  # ネスト関数は zsh ではグローバルに残るため _cm_ 接頭辞で名前空間衝突を避け、
  # cm 終了時に unfunction で後始末する（c() の #19 対応と同型＝#28）。
  _cm_build_prompt() {
    local extra_request="$1"
    if [[ -n "$extra_request" ]]; then
      printf '%s\n\nユーザーからの追加リクエスト: %s\n' "$BASE_PROMPT" "$extra_request"
    else
      printf '%s\n' "$BASE_PROMPT"
    fi
  }

  _cm_generate_commit_msg() {
    local extra_request="${1:-}"
    local prompt msg
    prompt=$(_cm_build_prompt "$extra_request")
    # msg=$(printf '%s\n\n%s' "$prompt" "$diff" | ssh win "ollama run qwen2.5:14b" 2>/dev/null)
    msg=$(printf '%s\n\n%s' "$prompt" "$diff" | claude -p -)
    msg=$(printf '%s' "$msg" | sed $'s/\033\\[[0-9;]*[mGKHF]//g')
    msg=${msg//$'\r'/}
    if [[ -z "$msg" ]]; then
      echo "Error: Failed to generate commit message." >&2
      return 1
    fi
    printf '%s' "$msg"
  }

  local commit_msg
  commit_msg=$(_cm_generate_commit_msg)

  if [[ "$SKIP_CONFIRM" == false ]]; then
    local answer feedback
    while true; do
      echo "Commit message: $commit_msg"
      read "answer?Proceed? [y/N]: "
      case "$answer" in
        [yY])
          break
          ;;
        [nN])
          read "feedback?Claudeにどう調整してほしいか入力してください: "
          if [[ -z "$feedback" ]]; then
            echo "フィードバックが空です。"
            continue
          fi
          commit_msg=$(_cm_generate_commit_msg "$feedback")
          ;;
        *)
          echo "Aborted."
          unfunction _cm_build_prompt _cm_generate_commit_msg 2>/dev/null
          return 0
          ;;
      esac
    done
  fi

  unfunction _cm_build_prompt _cm_generate_commit_msg 2>/dev/null

  git commit -m "$commit_msg"

  if [[ "$DO_PUSH" == true ]]; then
    git push
  fi
}
