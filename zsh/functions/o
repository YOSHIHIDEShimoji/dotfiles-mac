o() {
  local target="${1:-.}"
  if [[ -n "$WSL_DISTRO_NAME" ]] || grep -qi microsoft /proc/version 2>/dev/null; then
    if [[ "$target" == http://* || "$target" == https://* ]]; then
      cmd.exe /c start "$target" 2>/dev/null
    else
      local winpath
      winpath=$(wslpath -w "$target" 2>/dev/null || echo "$target")
      explorer.exe "$winpath"
    fi
  else
    xdg-open "$target"
  fi
}
