if [[ "$(uname)" == "Darwin" ]]; then
  ZDOTDIR="$HOME/dotfiles-mac/zsh"
else
  ZDOTDIR="$HOME/dotfiles-linux/zsh"
fi

# basic settings
source $ZDOTDIR/exports.sh
source $ZDOTDIR/aliases.sh

# functions（autoload）
FUNCTIONS_DIR="$ZDOTDIR/functions"
fpath=($FUNCTIONS_DIR $fpath)
for f in $FUNCTIONS_DIR/*(.N); do
  autoload -Uz "${f:t}"
done

# zsh-completions
if [[ "$(uname)" == "Darwin" ]]; then
  fpath=($(brew --prefix)/share/zsh-completions $fpath)
else
  fpath=(/usr/share/zsh/vendor-completions $fpath)
fi

# complement（1日以内のダンプがあれば -C で高速起動、無ければ/古ければフル実行＝#13）
autoload -Uz compinit
if [[ -n ${ZSH_COMPDUMP}(#qNmh-24) ]]; then
  compinit -C -d "$ZSH_COMPDUMP"
else
  compinit -d "$ZSH_COMPDUMP"
fi

# zsh-autosuggestions
if [[ "$(uname)" == "Darwin" ]]; then
  source "$(brew --prefix)/share/zsh-autosuggestions/zsh-autosuggestions.zsh"
else
  [[ -f /usr/share/zsh-autosuggestions/zsh-autosuggestions.zsh ]] && \
    source /usr/share/zsh-autosuggestions/zsh-autosuggestions.zsh
fi

# themes
eval "$(starship init zsh)"

# zsh-syntax-highlighting
if [[ "$(uname)" == "Darwin" ]]; then
  source "$(brew --prefix)/share/zsh-syntax-highlighting/zsh-syntax-highlighting.zsh"
else
  [[ -f /usr/share/zsh-syntax-highlighting/zsh-syntax-highlighting.zsh ]] && \
    source /usr/share/zsh-syntax-highlighting/zsh-syntax-highlighting.zsh
fi

# History search with arrow keys
autoload -Uz up-line-or-beginning-search down-line-or-beginning-search
zle -N up-line-or-beginning-search
zle -N down-line-or-beginning-search
bindkey "^[[A" up-line-or-beginning-search
bindkey "^[[B" down-line-or-beginning-search

# 挙動設定
setopt interactive_comments
setopt no_beep

# fzf（0.48未満は --zsh 非対応のためシステム統合ファイルを使う）
if command -v fzf >/dev/null 2>&1; then
  if fzf --zsh &>/dev/null; then
    source <(fzf --zsh)
  else
    [[ -f /usr/share/doc/fzf/examples/key-bindings.zsh ]] && source /usr/share/doc/fzf/examples/key-bindings.zsh
    [[ -f /usr/share/doc/fzf/examples/completion.zsh ]]   && source /usr/share/doc/fzf/examples/completion.zsh
  fi
fi

# pyenv
if command -v pyenv >/dev/null 2>&1; then
  eval "$(pyenv init -)"
  eval "$(pyenv virtualenv-init -)"
fi

# zoxide（末尾に配置必須）
# --cmd cd の doctor は cd 実行時に chpwd フックの有無で誤検知することがあり、
# ここで確実に最後に初期化しているため false-positive。警告を無効化する（#19）。
export _ZO_DOCTOR=0
if command -v zoxide >/dev/null 2>&1; then
  eval "$(zoxide init zsh --cmd cd)"
fi
