# ─── グローバル設定（全ホスト共通）────────────────────────
Host *
  # キープアライブ（接続ラグ・タイムアウト対策）
  ServerAliveInterval 60
  ServerAliveCountMax 3
  TCPKeepAlive yes

  # 接続多重化（同じホストへの2回目以降の接続を高速化）
  ControlMaster auto
  ControlPath ~/.ssh/cm/%r@%h:%p
  ControlPersist 10m

  # IPv4 優先（IPv6 フォールバックのラグ対策）
  AddressFamily inet

  # GSSAPI 認証の無効化（Kerberos 未使用環境での接続遅延対策）
  GSSAPIAuthentication no

# ─── 個人ホスト設定 ─────────────────────────────────────
# マシン固有ホスト（内部 IP・ユーザー名など）は追跡対象外の
# ~/.ssh/config.local に分離する（public リポジトリに晒さない = #16）。
# テンプレート: ssh/config.local.example（bootstrap.sh が未存在時にコピー）。
# 相対パスの Include は ~/.ssh 基準で解決され、ファイルが無くても無害。
Include config.local
