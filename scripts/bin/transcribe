#!/Users/yoshihide/.pyenv/versions/moodle-transcriber-3.11.9/bin/python
"""汎用文字起こしツール: ファイル or URL → faster-whisper → stdout + ファイル保存"""

import argparse
import os
import re
import readline
import signal
import sys
import tempfile
from pathlib import Path


def _err(msg: str) -> None:
    from tqdm import tqdm
    tqdm.write(msg, file=sys.stderr)


def _download_audio(url: str, out_dir: str) -> str:
    import yt_dlp

    out_tmpl = os.path.join(out_dir, "%(title)s.%(ext)s")
    ydl_opts = {
        "format": "bestaudio/best",
        "outtmpl": out_tmpl,
        "postprocessors": [
            {
                "key": "FFmpegExtractAudio",
                "preferredcodec": "wav",
                "preferredquality": "192",
            }
        ],
        "quiet": True,
        "no_warnings": True,
    }

    _err("[download] 音声を取得中...")
    with yt_dlp.YoutubeDL(ydl_opts) as ydl:
        ydl.extract_info(url, download=True)

    for f in Path(out_dir).iterdir():
        if f.suffix == ".wav":
            return str(f)

    raise RuntimeError(f"ダウンロード後の wav ファイルが見つかりません: {out_dir}")


def _is_url(s: str) -> bool:
    return s.startswith(("http://", "https://", "ftp://"))


def _fmt_time(seconds: float) -> str:
    h = int(seconds // 3600)
    m = int((seconds % 3600) // 60)
    s = seconds % 60
    if h:
        return f"{h:02d}:{m:02d}:{s:05.2f}"
    return f"{m:02d}:{s:05.2f}"


def _sanitize_filename(name: str) -> str:
    name = re.sub(r'[\\/:*?"<>|]', "_", name)
    return name.strip()[:200]


def _prompt_rename(current_path: Path, timeout: int = 60) -> Path:
    ext = current_path.suffix
    prefill = current_path.stem

    readline.set_startup_hook(lambda: readline.insert_text(prefill))
    sys.stderr.write(f"\nファイル名を編集 (拡張子{ext}は自動付与、{timeout}秒で自動確定): ")
    sys.stderr.flush()

    def _on_timeout(sig, frame):
        raise TimeoutError()

    old_handler = signal.signal(signal.SIGALRM, _on_timeout)
    signal.alarm(timeout)
    try:
        answer = input()
        signal.alarm(0)
    except (TimeoutError, EOFError, KeyboardInterrupt):
        sys.stderr.write("\n")
        answer = ""
    finally:
        signal.alarm(0)
        signal.signal(signal.SIGALRM, old_handler)
        readline.set_startup_hook(None)

    new_stem = answer.strip()
    if new_stem.lower().endswith(ext.lower()):
        new_stem = new_stem[: -len(ext)]
    new_stem = _sanitize_filename(new_stem)

    if not new_stem or new_stem == current_path.stem:
        return current_path

    new_path = current_path.with_name(new_stem + ext)
    current_path.rename(new_path)
    return new_path


def _srt_ts(t: float) -> str:
    h = int(t // 3600)
    m = int((t % 3600) // 60)
    s = t % 60
    ms = int((s - int(s)) * 1000)
    return f"{h:02d}:{m:02d}:{int(s):02d},{ms:03d}"


def _format_line(seg: dict, fmt: str, seg_id: int) -> str:
    if fmt == "srt":
        return f"{seg_id}\n{_srt_ts(seg['start'])} --> {_srt_ts(seg['end'])}\n{seg['text']}\n"
    elif fmt == "txt":
        return f"[{_fmt_time(seg['start'])}] {seg['text']}\n"
    else:  # plain
        return seg["text"] + "\n"


def main() -> None:
    parser = argparse.ArgumentParser(
        description="音声/動画ファイルまたはURLを文字起こしする",
        formatter_class=argparse.RawDescriptionHelpFormatter,
        epilog="""\
examples:
  transcribe lecture.mp4
  transcribe lecture.mp4 --lang en
  transcribe lecture.mp4 --format txt        # タイムスタンプ付き
  transcribe lecture.mp4 --format srt        # 字幕ファイル
  transcribe lecture.mp4 -o output.txt       # ファイル名指定（リネームプロンプトなし）
  transcribe https://example.com/video.mp4
  transcribe https://www.youtube.com/watch?v=xxxxx --lang en
  transcribe lecture.mp4 | pbcopy           # クリップボードにコピー
""",
    )
    parser.add_argument("input", help="音声/動画ファイルパス、またはURL")
    parser.add_argument(
        "-o", "--output",
        help="出力ファイルパス (省略時はカレントディレクトリに自動保存)",
    )
    parser.add_argument(
        "--format",
        choices=["txt", "srt", "plain"],
        default="plain",
        help="出力フォーマット: txt=タイムスタンプ付き, srt=字幕, plain=テキストのみ (default: plain)",
    )
    parser.add_argument("--lang", default="ja", help="言語コード (default: ja)")
    parser.add_argument(
        "--model",
        default="large-v3",
        help="Whisperモデルサイズ (default: large-v3)",
    )
    parser.add_argument(
        "--device", default="cpu", choices=["cpu", "cuda"], help="推論デバイス (default: cpu)"
    )
    args = parser.parse_args()

    src = args.input
    tmpdir = None
    interrupted = False

    def _handle_sigint(sig, frame):
        nonlocal interrupted
        interrupted = True

    signal.signal(signal.SIGINT, _handle_sigint)

    try:
        if _is_url(src):
            tmpdir = tempfile.mkdtemp(prefix="transcribe_")
            audio_path = _download_audio(src, tmpdir)
            stem = Path(audio_path).stem
        else:
            audio_path = src
            if not Path(audio_path).exists():
                _err(f"[error] ファイルが見つかりません: {audio_path}")
                sys.exit(1)
            stem = Path(audio_path).stem

        ext = "srt" if args.format == "srt" else "txt"
        if args.output:
            out_path = Path(args.output)
            prompt_rename = False
        else:
            out_path = Path(f"{_sanitize_filename(stem)}.{ext}")
            prompt_rename = True

        _err(f"[model] {args.model} をロード中...")
        from faster_whisper import WhisperModel

        compute_type = "float16" if args.device == "cuda" else "int8"
        model = WhisperModel(
            args.model,
            device=args.device,
            compute_type=compute_type,
            cpu_threads=8,
        )

        _err(f"[transcribe] 文字起こし開始: {Path(audio_path).name}")
        _err(f"[output] {out_path.resolve()}")

        segments_iter, info = model.transcribe(
            audio_path,
            language=args.lang,
            beam_size=5,
            vad_filter=True,
            vad_parameters={"min_silence_duration_ms": 500},
        )

        duration = info.duration or 0.0
        seg_id = 1
        seg_count = 0
        is_tty = sys.stdout.isatty()

        from tqdm import tqdm

        bar_fmt = "{l_bar}{bar}| {n:.0f}/{total:.0f}s [{elapsed}<{remaining}]"
        with tqdm(
            total=duration,
            unit="s",
            bar_format=bar_fmt,
            file=sys.stderr,
            dynamic_ncols=True,
            disable=not is_tty,
        ) as pbar:
            with out_path.open("w", encoding="utf-8") as f:
                for seg in segments_iter:
                    if interrupted:
                        break

                    text = seg.text.strip()
                    if not text:
                        continue

                    line = _format_line(
                        {"start": seg.start, "end": seg.end, "text": text},
                        args.format,
                        seg_id,
                    )

                    if is_tty:
                        # ターミナル: バーの上にテキストを1回だけ表示
                        tqdm.write(line, end="", file=sys.stderr)
                    else:
                        # パイプ: stdout にストリーミング
                        sys.stdout.write(line)
                        sys.stdout.flush()

                    f.write(line)
                    f.flush()

                    pbar.update(seg.end - pbar.n)
                    seg_id += 1
                    seg_count += 1

        status = "中断" if interrupted else "完了"
        _err(f"[{status}] {seg_count} セグメント")

        if prompt_rename:
            out_path = _prompt_rename(out_path)

        _err(f"[saved] {out_path.resolve()}")

    finally:
        if tmpdir:
            import shutil
            shutil.rmtree(tmpdir, ignore_errors=True)


if __name__ == "__main__":
    main()
