#!/usr/bin/env bash
# 文字起こしツール: whisper.cpp + CoreML（M4 Neural Engine）
# 処理時間の目安 (M4 / large-v3-turbo):
#   30分 → 約1分30秒, 1時間 → 約3分, 2時間 → 約6分, 3時間 → 約9分

set -euo pipefail

WHISPER_CLI=~/my-projects/whisper.cpp/build/bin/whisper-cli
WHISPER_MODEL=~/my-projects/whisper.cpp/models/ggml-large-v3-turbo.bin

usage() {
  cat <<EOF
Usage: transcribe <input> [-o output] [--lang ja] [--format plain|txt|srt]

処理時間の目安 (M4 / whisper.cpp + CoreML + large-v3-turbo):
  30分の音声  → 約1分30秒
  1時間の音声 → 約3分
  2時間の音声 → 約6分
  3時間の音声 → 約9分

Options:
  -o, --output PATH    出力ファイルパス (省略時はカレントディレクトリに自動保存)
  --lang LANG          言語コード (default: ja)
  --format FORMAT      plain=テキストのみ, txt=タイムスタンプ付き, srt=字幕 (default: plain)
  --summary            文字起こし後に Windows の Ollama で要約し、箇条書きをファイル先頭に追記
  --summary-model M    要約に使うモデル (default: qwen2.5:14b)
  -h, --help

Examples:
  transcribe voice_memo.m4a
  transcribe voice_memo.m4a -o ~/Desktop/output.txt
  transcribe voice_memo.m4a --lang en --format srt
  transcribe voice_memo.m4a --summary
  transcribe voice_memo.m4a | pbcopy
EOF
}

INPUT=""
OUTPUT=""
# 言語コード。環境変数 LANG（ロケール）とは別物にするため LANG_CODE を使う。
# LANG に代入すると子プロセス（ffmpeg / whisper-cli）へ不正ロケールとして伝播する（#28）。
LANG_CODE="ja"
FORMAT="plain"
SUMMARY=0
# 要約に使う Windows 上の Ollama モデル（cm / ask と同じ既定）
SUMMARY_MODEL="qwen2.5:14b"

while [[ $# -gt 0 ]]; do
  case "$1" in
    -h|--help) usage; exit 0 ;;
    -o|--output) OUTPUT="$2"; shift 2 ;;
    --lang) LANG_CODE="$2"; shift 2 ;;
    --format) FORMAT="$2"; shift 2 ;;
    --summary) SUMMARY=1; shift ;;
    --summary-model) SUMMARY_MODEL="$2"; shift 2 ;;
    -*) echo "Unknown option: $1" >&2; usage; exit 1 ;;
    *) INPUT="$1"; shift ;;
  esac
done

if [[ -z "$INPUT" ]]; then
  usage; exit 1
fi

if [[ ! -f "$INPUT" ]]; then
  echo "[error] ファイルが見つかりません: $INPUT" >&2
  exit 1
fi

# WAV以外はffmpegで16kHz mono WAVに変換
TMPWAV=""
if [[ "${INPUT##*.}" != "wav" ]]; then
  TMPWAV=$(mktemp /tmp/transcribe_XXXXXX.wav)
  echo "[convert] ${INPUT##*/} → 16kHz mono wav ..." >&2
  ffmpeg -i "$INPUT" -ar 16000 -ac 1 -c:a pcm_s16le "$TMPWAV" -y -loglevel error
  AUDIO="$TMPWAV"
else
  AUDIO="$INPUT"
fi

cleanup() {
  [[ -n "$TMPWAV" ]] && rm -f "$TMPWAV"
}
trap cleanup EXIT

STEM=$(basename "$INPUT")
STEM="${STEM%.*}"

case "$FORMAT" in
  srt) EXT="srt" ;;
  *)   EXT="txt" ;;
esac

if [[ -z "$OUTPUT" ]]; then
  OUTPUT_BASE="${STEM}"
else
  OUTPUT_BASE="${OUTPUT%.*}"
fi

echo "[model] $WHISPER_MODEL (CoreML)" >&2
echo "[transcribe] 文字起こし開始: ${INPUT##*/}" >&2
echo "[output] ${OUTPUT_BASE}.${EXT}" >&2

WHISPER_FLAGS=(-m "$WHISPER_MODEL" -f "$AUDIO" -l "$LANG_CODE" -of "$OUTPUT_BASE")

case "$FORMAT" in
  srt)   WHISPER_FLAGS+=(-osrt) ;;
  txt)   WHISPER_FLAGS+=(-otxt) ;;
  plain) WHISPER_FLAGS+=(-otxt --no-timestamps) ;;
esac

"$WHISPER_CLI" "${WHISPER_FLAGS[@]}" 2>/dev/null

SEG_COUNT=$(grep -c "." "${OUTPUT_BASE}.${EXT}" 2>/dev/null || echo 0)
echo "[完了] ${SEG_COUNT} 行" >&2
echo "[saved] $(realpath "${OUTPUT_BASE}.${EXT}")" >&2

# --summary: Windows の Ollama で要約し、箇条書きをファイル先頭に追記する（#7）。
# 要約に失敗しても文字起こし本体は保存済みなので、非致命扱いで警告だけ出す。
if [[ "$SUMMARY" -eq 1 ]]; then
  OUT_FILE="${OUTPUT_BASE}.${EXT}"
  echo "[summary] Windows の Ollama (${SUMMARY_MODEL}) で要約中 ..." >&2
  SUMMARY_PROMPT=$'以下は音声の文字起こしです。日本語で要約してください。各項目は「- 」で始まる箇条書きにし、重要な点だけを簡潔に。前置き・見出し・締めの文は不要です。\n\n'
  # ssh win 経由で要約を取得。set -e/pipefail 下で ssh 失敗が致命化しないよう || true で受ける。
  SUMMARY_TEXT=$(printf '%s%s' "$SUMMARY_PROMPT" "$(cat "$OUT_FILE")" \
    | ssh win "ollama run ${SUMMARY_MODEL}" 2>/dev/null \
    | sed $'s/\r$//') || true
  if [[ -n "$SUMMARY_TEXT" ]]; then
    TMP_SUM=$(mktemp /tmp/transcribe_sum_XXXXXX)
    {
      printf '%s\n\n---\n\n' "$SUMMARY_TEXT"
      cat "$OUT_FILE"
    } > "$TMP_SUM"
    mv "$TMP_SUM" "$OUT_FILE"
    echo "[summary] 要約をファイル先頭に追記しました" >&2
  else
    echo "[summary] 要約に失敗しました（win 未接続 / Ollama 未起動?）。文字起こし本体は保存済みです。" >&2
  fi
fi
